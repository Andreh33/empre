# =====================================================================
# Asesoria Empresarial Juan Garcia S.L. - Variables de entorno
# ---------------------------------------------------------------------
# Copiar a .env.local para desarrollo (NUNCA commitear .env.local).
# En produccion, cargar todas estas variables en Vercel:
#   Project -> Settings -> Environment Variables (Production / Preview).
# =====================================================================

# ---------------------------------------------------------------------
# Base de datos: Turso (libSQL) - region AWS EU-West-1 (Irlanda)
# ---------------------------------------------------------------------
TURSO_DATABASE_URL="libsql://asesoria-andreh.aws-eu-west-1.turso.io"
TURSO_AUTH_TOKEN=""

# ---------------------------------------------------------------------
# Cifrado de campos sensibles (DNI, IBAN, NSS, CIF...)
# Generar con: openssl rand -base64 32
# 32 bytes en base64. NO rotar sin plan de re-cifrado.
# ---------------------------------------------------------------------
ENCRYPTION_KEY=""

# Clave HMAC para hashes deterministas de busqueda (DNI, email...)
# Generar con: openssl rand -base64 32
SEARCH_HMAC_KEY=""

# ---------------------------------------------------------------------
# Auth.js (NextAuth v5)
# Generar NEXTAUTH_SECRET con: openssl rand -base64 32
# ---------------------------------------------------------------------
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# ---------------------------------------------------------------------
# Vercel Blob (almacenamiento de archivos en region UE)
# Obtener en Vercel: Storage -> Blob -> Connect.
# ---------------------------------------------------------------------
BLOB_READ_WRITE_TOKEN=""

# ---------------------------------------------------------------------
# Resend (email transaccional)
# https://resend.com/api-keys
# ---------------------------------------------------------------------
RESEND_API_KEY=""
RESEND_FROM_EMAIL="no-reply@asesoria-juangarcia.es"

# ---------------------------------------------------------------------
# Cloudflare Turnstile (CAPTCHA en login/registro)
# https://developers.cloudflare.com/turnstile/
# ---------------------------------------------------------------------
TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# ---------------------------------------------------------------------
# Upstash Redis (rate limiting)
# https://upstash.com/  -> region eu-west-1
# ---------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ---------------------------------------------------------------------
# VirusTotal (antivirus de archivos subidos)
# https://www.virustotal.com/gui/my-apikey
# ---------------------------------------------------------------------
VIRUSTOTAL_API_KEY=""

# ---------------------------------------------------------------------
# Sentry (monitorizacion - opcional, recomendado en produccion)
# ---------------------------------------------------------------------
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

# ---------------------------------------------------------------------
# Configuracion de la aplicacion
# ---------------------------------------------------------------------
APP_NAME="Asesoria Empresarial Juan Garcia S.L."
APP_URL="http://localhost:3000"
NODE_ENV="development"
MAX_UPLOAD_SIZE_MB="50"
SESSION_INACTIVITY_MINUTES="15"
SESSION_ABSOLUTE_HOURS="8"
